algoritmo "Ano de nascimento"

var

 nascimento: inteiro
 idade: inteiro

inicio

    escreva("De a sua data de nascimento: ")
    leia(nascimento)
    idade <- 2026 - nascimento
    se(idade >= 16)entao
        escreval("Vc tem idade pra votar")
    fimse
    se(idade >= 18) entao
        escreval("Vc tem idade pra tirar carteira de motorista")
    fimse




fimalgoritmo